# Copy this file to .env and fill in the values before starting the server.
# You can place the .env file in either the root directory or the backend/ directory.
# The server will refuse to start if JWT_SECRET or MONGO_URI are missing.

# MongoDB connection string (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT signing secret -- use a long random string (minimum 32 characters)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Server port (optional, defaults to 10002)
PORT=10002
